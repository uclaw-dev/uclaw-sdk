{
  "name": "uclaw-sdk",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "fmt": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "tc": "bun run --filter @uclaw/* tc",
    "build": "tsdown -W",
    "update:all": "bun update --recursive --interactive",
    "ci:version": "changeset version && bun update",
    "ci:publish": "for dir in packages/*; do (cd \"$dir\" && bun pm pack && npm publish *.tgz || true); done && changeset tag",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.73.0",
    "tsdown": "^0.22.7"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
