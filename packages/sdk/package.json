{
  "name": "@uclaw/sdk",
  "version": "0.1.3",
  "description": "Official TypeScript SDK for UClaw, a managed runtime for stateful AI agents.",
  "keywords": [
    "agents",
    "ai",
    "cloudflare",
    "llm",
    "react",
    "sdk",
    "typescript"
  ],
  "homepage": "https://uclaw.dev",
  "bugs": {
    "url": "https://github.com/uclaw-dev/uclaw-sdk/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uclaw-dev/uclaw-sdk.git",
    "directory": "packages/sdk"
  },
  "files": [
